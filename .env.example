# ============================================================
# Hosting Platform — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# --- Server ---
PORT=8080
ENVIRONMENT=development

# --- Database ---
# Option 1: Single URL (for RDS or any remote PostgreSQL)
DATABASE_URL=postgresql://user:password@your-db.xxxxx.af-south-1.rds.amazonaws.com:5432/hostingplatform?sslmode=require

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# --- SES ---
SES_REGION=us-east-1

# --- Route53 ---
PLATFORM_DOMAIN=tishanyq.co.zw
PLATFORM_ZONE_ID=Z1234567890

# --- EC2 ---
EC2_PUBLIC_IP=1.2.3.4

# --- Mail Server ---
MAIL_SERVER_HOST=mail.tishanyq.co.zw

# --- Nginx ---
NGINX_SITES_DIR=/etc/nginx/sites-available
NGINX_ENABLED_DIR=/etc/nginx/sites-enabled
SITES_ROOT_DIR=/var/www

# --- Docker ---
DOCKER_NETWORK=customer-net
PORT_RANGE_START=10000
PORT_RANGE_END=10999

# --- SSL (Let's Encrypt) ---
CERTBOT_EMAIL=admin@tishanyq.co.zw

# --- JWT ---
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRE_HOURS=24
